# environments/prod.tfvars.example
# Copy to prod.tfvars and fill in your values

# github data
github_owner    = "github-user-name"
repository_name = "your-project-name"

# Rulesets - Module
rulesets = {
  branch-name = {
    target_branches     = ["target-branches"]
    enforcement         = "active"
    required_signatures = true
    require_pull_request = {
      dismiss_stale_reviews_on_push = false
      require_last_push_approval    = false
      required_approvals            = 1
      allowed_merge_methods         = [ "squash", "merge", "rebase" ]
    }
    deployment_environments = ["environment-name"]
    required_checks         = ["checks-name-1", "checks-name-2"]
  }
}

# Environments - Module
environment_creation = {
  environment-name = {
    prevent_self_review = bool
    wait_timer          = number
    reviewers           = number
    branch_policy = {
      protected_branches = bool
    }
  }

  environment-name = {
    prevent_self_review = bool
    wait_timer          = number
    reviewers           = number
    branch_policy = {
      protected_branches = bool
    }
  }
}

# GHA Variables and Secrets - Module
repo_variables = {
  VAR_NAME = "value"
}

repo_secrets = {
  SECRET_NAME = "value"
}

environment_variables = {
  prod = {
    VAR_NAME = "value"
  }
  dev = {
    VAR_NAME = "value"
  }
}

environment_secrets = {
  prod = {
    SECRET_NAME = "value"
  }
  dev = {
    SECRET_NAME = "value"
  }
}

# Repo Settings
labels = {
  label-name = {
    color       = "label-color"
    description = "label-description"
  }
}
